{
  "name": "app",
  "version": "0.0.1",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "e2e:install": "cd tests/e2e && bun install && bun run install:browsers",
    "e2e": "cd tests/e2e && bun run test",
    "e2e:headed": "cd tests/e2e && bun run test:headed"
  },
  "packageManager": "bun@1.3.9",
  "devDependencies": {
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "eslint": "^10.1.0",
    "prettier": "^3.8.1",
    "turbo": "^2.8.21",
    "typescript": "6.0.2"
  }
}