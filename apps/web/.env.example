# ====================================================================================
# Web App - Local Development Environment Variables
# ====================================================================================
# Copy this file to .env.local and fill in your actual values
# .env.local is gitignored and used for local development only
#
# For Docker/Production: Values are injected via docker-compose.yml
# ====================================================================================

# ─── API URLs ────────────────────────────────────────────────────────────────
# Browser-facing — must be reachable from the user's browser
NEXT_PUBLIC_API_URL=http://localhost:4000

# Server-side fetch (Server Actions, RSC) — uses Docker internal hostname in prod
# In local dev: same as NEXT_PUBLIC_API_URL
API_URL=http://localhost:4000

# Site URL (used for absolute URLs)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Auth (JWT) ──────────────────────────────────────────────────────────────
# MUST match apps/server's JWT_SECRET. The web app verifies JWTs locally to
# avoid an extra round-trip to /api/auth/me on every render.
# Generate: openssl rand -hex 64
JWT_SECRET=your-64-char-random-string-here
