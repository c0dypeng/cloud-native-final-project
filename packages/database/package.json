{
  "name": "@workspace/database",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist", "drizzle"],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "seed": "tsx src/seed.ts",
    "seed:load": "SEED_SCALE=load tsx src/seed.ts",
    "lint": "echo 'no lint for database'",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@faker-js/faker": "^9.5.0",
    "bcryptjs": "^2.4.3",
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@workspace/typescript-config": "workspace:*",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.21.0",
    "typescript": "^5.9.2"
  }
}
