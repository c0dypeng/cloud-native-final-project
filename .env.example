# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=your-postgres-password-here

# Connection string used by apps/server and packages/database seed script
# Dev local:       postgresql://safety:your-password@localhost:5432/safetydb
# Dev Docker:      postgresql://safety:your-password@pgbouncer:6432/safetydb
# Prod Docker/K8s: postgresql://safety:your-password@pgbouncer:6432/safetydb
DATABASE_URL=postgresql://safety:your-postgres-password-here@localhost:5432/safetydb

# ─── Auth (JWT) ──────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 64
# Must be the SAME value in apps/server and apps/web
JWT_SECRET=your-64-char-random-string-here
JWT_EXPIRES_IN=8h

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=4000
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# ─── Redis (stats cache + reminder counters) ─────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Email (Resend) ──────────────────────────────────────────────────────────
# Get a free API key at https://resend.com (100 emails/day on free tier)
# Leave empty to disable email — reminders will still appear via SSE in-app.
RESEND_API_KEY=
RESEND_FROM_EMAIL=no-reply@huyouan.local

# ─── Web app (apps/web) ──────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000   # browser-facing API URL
API_URL=http://server:4000                  # SSR / server actions (Docker internal)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Seed ────────────────────────────────────────────────────────────────────
# Used by: make seed / make seed:load
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=changeme
SEED_USER_PASSWORD=password123
SEED_SCALE=demo                              # demo (100 users) | load (10k users)

# ─── Observability (optional) ────────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=admin
