# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=your-postgres-password-here
DATABASE_URL=postgresql://safety:your-postgres-password-here@localhost:5432/safetydb

# ─── Auth (JWT) ──────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 64
JWT_SECRET=your-64-char-random-string-here
JWT_EXPIRES_IN=8h

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=4000
# Comma-separated list of allowed origins (web + admin, http + https).
CORS_ORIGIN=http://cloud-native-final-project.ntu-bilab.com,http://admin-cloud-native-final-project.ntu-bilab.com,https://cloud-native-final-project.ntu-bilab.com,https://admin-cloud-native-final-project.ntu-bilab.com

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Email (Resend) ──────────────────────────────────────────────────────────
# Free key at https://resend.com (100 emails/day). Empty = log to stdout.
RESEND_API_KEY=
RESEND_FROM_EMAIL=no-reply@huyouan.local

# ─── Web app (apps/web) ──────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://cloud-native-final-project.ntu-bilab.com
API_URL=http://server:4000
NEXT_PUBLIC_SITE_URL=http://cloud-native-final-project.ntu-bilab.com

# ─── Seed ────────────────────────────────────────────────────────────────────
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=changeme
SEED_USER_PASSWORD=password123
SEED_SCALE=demo

# ─── Observability ───────────────────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=admin
