{
  "annotations": { "list": [] },
  "editable": true,
  "title": "護你安 · Backing Services",
  "uid": "huyouan-backing",
  "tags": ["huyouan", "postgres", "redis"],
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-30m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Node memory used (server)",
      "gridPos": { "x": 0, "y": 0, "w": 8, "h": 6 },
      "targets": [
        {
          "expr": "process_resident_memory_bytes{job=\"server\"}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Event-loop lag (max p95)",
      "gridPos": { "x": 8, "y": 0, "w": 8, "h": 6 },
      "targets": [
        {
          "expr": "max(nodejs_eventloop_lag_p95_seconds) * 1000",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Heap used (server)",
      "gridPos": { "x": 16, "y": 0, "w": 8, "h": 6 },
      "targets": [
        {
          "expr": "nodejs_heap_size_used_bytes{job=\"server\"}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Cache hits vs misses (per minute)",
      "gridPos": { "x": 0, "y": 6, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(stats_cache_hits_total[1m]) * 60",
          "legendFormat": "hits",
          "refId": "A"
        },
        {
          "expr": "rate(stats_cache_misses_total[1m]) * 60",
          "legendFormat": "misses",
          "refId": "B"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "SSE active connections",
      "gridPos": { "x": 12, "y": 6, "w": 12, "h": 8 },
      "targets": [
        { "expr": "sse_active_connections", "refId": "A" }
      ]
    }
  ]
}
