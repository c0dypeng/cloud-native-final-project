{
  "annotations": { "list": [] },
  "editable": true,
  "title": "護你安 · Safety SLO",
  "uid": "huyouan-slo",
  "tags": ["huyouan", "slo"],
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Report submit success rate (last 5m)",
      "gridPos": { "x": 0, "y": 0, "w": 8, "h": 6 },
      "targets": [
        {
          "expr": "sum(rate(report_submit_total{result=\"success\"}[5m])) / sum(rate(report_submit_total[5m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.99 },
              { "color": "green", "value": 0.995 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Report submit p95 (ms)",
      "gridPos": { "x": 8, "y": 0, "w": 8, "h": 6 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{route=~\".*/report\"}[5m])) by (le)) * 1000",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 400 },
              { "color": "red", "value": 500 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Reminder emails (last 1h)",
      "gridPos": { "x": 16, "y": 0, "w": 8, "h": 6 },
      "targets": [
        {
          "expr": "sum(increase(reminder_emails_total{result=\"sent\"}[1h]))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Need-help reports (per minute)",
      "gridPos": { "x": 0, "y": 6, "w": 24, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(report_submit_total{status=\"need_help\",result=\"success\"}[1m])) * 60",
          "legendFormat": "need_help/min",
          "refId": "A"
        }
      ]
    }
  ]
}
